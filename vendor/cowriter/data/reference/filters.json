  "keyword_groups": [
    {
      "_note": "사용자 정의 영역 — 아래는 예시. label은 칩 이름, any는 이 중 하나라도 매칭되면 포함. search_in에 지정한 필드들에서 대소문자 무시하고 부분일치.",
      "label": "예시: 재벌/CEO",
      "any": [
        "재벌",
        "CEO",
        "billionaire",
        "회장",
        "보스"
      ],
      "search_in": [
        "desc",
        "script.line",
        "hook_desc"
      ]
    },
    {
      "label": "예시: 계약/위장결혼",
      "any": [
        "계약",
        "위장",
        "가짜",
        "contract",
        "fake"
      ],
      "search_in": [
        "desc",
        "script.line",
        "hook_desc"
      ]
    }
  ],
  "exclude_keywords": {
    "_note": "이 키워드가 desc/script에 있으면 목록에서 숨김 (전역 제외). 비워두면 제외 없음.",
    "any": [],
    "search_in": [
      "desc",
      "script.line"
    ]
